# Paperless-AI Configuration

# Paperless API connection
PAPERLESS_BASE_URL=http://paperless-ngx:8000
PAPERLESS_API_TOKEN=changeme_get_from_paperless_ui

# Ollama connection
OLLAMA_HOST=http://paperless-ollama:11434

# Model to use for metadata suggestions
# Recommended: llama3.2:3b (fast and good quality)
# Alternatives: mistral, llama3.1:8b, qwen2.5:7b
OLLAMA_MODEL=llama3.2:3b

# Optional: Customize processing
# PAPERLESS_AI_AUTO_TAG=true
# PAPERLESS_AI_AUTO_CORRESPONDENT=true
# PAPERLESS_AI_AUTO_DOCTYPE=true
