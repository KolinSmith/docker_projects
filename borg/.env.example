# =============================================================================
# Beszel Agent Configuration
# =============================================================================
# Get SSH key from Beszel hub web UI

# SSH public key from Beszel hub (required)
# 1. Access Beszel hub: http://192.168.9.2:8090 (or Voyager IP)
# 2. Add new system: "Unraid"
# 3. Copy the SSH public key
# 4. Paste it below
BESZEL_AGENT_KEY=ssh-ed25519_AAAAC3...your_key_here

# =============================================================================
# Paperless-ngx Configuration
# =============================================================================

# Database credentials (must match between Paperless and PostgreSQL)
PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=paperless
PAPERLESS_DBPASS=changeme_secure_password_here

# Secret key for Paperless (generate with: openssl rand -base64 32)
PAPERLESS_SECRET_KEY=changeme_generate_random_key_here

# Paperless URL (adjust to your Unraid IP or hostname)
PAPERLESS_URL=http://borg:8000

# Timezone
TZ=America/New_York

# OCR language (eng, deu, fra, spa, etc. - see Paperless docs for full list)
PAPERLESS_OCR_LANGUAGE=eng

# Consume directory (where you drop files to ingest)
PAPERLESS_CONSUME_DIR=/mnt/user/Documents/consume

# =============================================================================
# Paperless AI Services Configuration
# =============================================================================

# API Token for Paperless-AI and Paperless-GPT
# Generate this in Paperless web UI: Profile → API Tokens
PAPERLESS_API_TOKEN=changeme_get_from_paperless_ui

# Ollama model for Paperless-AI metadata suggestions
# Recommended: llama3.2:3b (fast, good quality)
# Alternatives: mistral, llama3.1:8b, qwen2.5:7b
PAPERLESS_AI_MODEL=llama3.2:3b

# Vision model for Paperless-GPT OCR enhancement
# Recommended: minicpm-v:8b (excellent OCR, GPU accelerated)
# Alternatives: llava:7b, llava:13b
PAPERLESS_GPT_VISION_MODEL=minicpm-v:8b
