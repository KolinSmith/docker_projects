TZ=America/Chicago

# CPU CORRECTION BUG — must re-apply after every Dockhand image update
#
# Dockhand's subprocess-manager ignores cpuCount for the local docker.sock path,
# so CPU% shows as (cores × actual%) instead of actual%. The Hawser path is fine.
#
# Patched file inside container:
#   /app/build/server/chunks/subprocess-manager-JT2DwB2e.js
#
# Find and replace (once per update):
#   BEFORE: E(e.envId,e.cpu,e.memPercent
#   AFTER:  E(e.envId,e.cpuCount>0?e.cpu/e.cpuCount:e.cpu,e.memPercent
#
# Quick re-apply (run after pulling new image):
#   docker exec dockhand node -e "
#     const fs=require('fs');
#     const f='/app/build/server/chunks/subprocess-manager-*.js';
#     require('glob').sync(f).forEach(p=>{
#       let d=fs.readFileSync(p,'utf8');
#       d=d.replace('E(e.envId,e.cpu,e.memPercent','E(e.envId,e.cpuCount>0?e.cpu/e.cpuCount:e.cpu,e.memPercent');
#       fs.writeFileSync(p,d);
#     });
#     console.log('patched');
#   "
#   docker restart dockhand
