# ==============================================================================
# BORG STACK — Environment Variables
# Copy to .env and fill in your values. Never commit .env.
# ==============================================================================

# ==============================================================================
# GLOBAL
# ==============================================================================

# Server timezone
TZ=America/Chicago

# Unraid user/group IDs (Unraid defaults — run `id nobody` to confirm)
PUID=99
PGID=100

# Unraid server IP address
UNRAID_IP=192.168.9.7

# ==============================================================================
# BESZEL AGENT — System monitoring agent
# Get KEY from Beszel hub web UI after adding this system
# ==============================================================================

BESZEL_AGENT_KEY=ssh-ed25519 AAAA...your-key-here

# ==============================================================================
# NVIDIA GPU
# Run: nvidia-smi --query-gpu=uuid --format=csv,noheader
# Used by: binhex-plexpass, ErsatzTV
# ==============================================================================

NVIDIA_GPU_UUID=GPU-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ==============================================================================
# SPEEDTEST TRACKER — Internet speed monitoring
# APP_KEY: run `openssl rand -base64 32` then prefix with `base64:`
# SPEEDTEST_SERVERS: comma-separated Ookla server IDs (empty = auto-select)
# SPEEDTEST_SCHEDULE: cron expression (*/3 * * * * = every 3 minutes)
# SPEEDTEST_PRUNE_RESULTS_OLDER_THAN: days to retain (0 = keep all)
# ==============================================================================

SPEEDTEST_APP_KEY=base64:changeme=
SPEEDTEST_SCHEDULE=*/3 * * * *
SPEEDTEST_SERVERS=38364,22288,69553,1272,26652,72163,56809
SPEEDTEST_PRUNE_RESULTS_OLDER_THAN=0

# ==============================================================================
# ICLOUDPD — iCloud Photos downloader (uncomment when enabling)
# ==============================================================================

# ICLOUD_APPLE_ID=your@apple.com
# ICLOUD_SYNC_INTERVAL=86400

# ==============================================================================
# CHECKMATE — Uptime & status monitoring (uncomment when enabling)
# DB_CONNECTION_STRING: MongoDB URI pointing to mongodb_checkmate container
# REDIS_URL: Redis URI pointing to redis_checkmate container
# ==============================================================================

# CHECKMATE_CLIENT_HOST=http://borg:3001
# CHECKMATE_UPTIME_APP_API_BASE_URL=http://borg:52343/api/v1
# CHECKMATE_UPTIME_APP_CLIENT_HOST=http://borg:3001
# CHECKMATE_DB_CONNECTION_STRING=mongodb://mongodb_checkmate:27017/checkmate
# CHECKMATE_JWT_SECRET=changeme-long-random-secret
# CHECKMATE_TOKEN_TTL=3600000
# CHECKMATE_ORIGIN=http://borg:3001
# CHECKMATE_REDIS_URL=redis://redis_checkmate:6379
