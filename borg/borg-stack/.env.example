# ==============================================================================
# BORG STACK — Environment Variables
# Copy to .env and fill in your values. Never commit .env.
# ==============================================================================

# ==============================================================================
# GLOBAL
# ==============================================================================

# Server timezone
TZ=America/Chicago

# Unraid user/group IDs (run `id` on Unraid to find yours)
PUID=1000
PGID=1000

# Unraid server IP address (used by Plex ADVERTISE_IP)
UNRAID_IP=192.168.9.7

# Local network CIDR (used by Plex ALLOWED_NETWORKS)
LOCAL_NETWORK=192.168.0.0/16

# Shared network used by NZBHydra2
SHARED_NETWORK=192.168.9.0/24

# ==============================================================================
# BESZEL AGENT — System monitoring agent
# Get KEY from Beszel hub web UI after adding this system
# ==============================================================================

BESZEL_AGENT_KEY=your-beszel-ssh-public-key-here

# ==============================================================================
# PLEX — Media server
# Get claim token from: https://www.plex.tv/claim (expires in 4 minutes)
# ==============================================================================

PLEX_CLAIM=claim-xxxxxxxxxxxxxxxxxxxx

# ==============================================================================
# KOMETA — Plex metadata manager
# See: https://kometa.wiki
# ==============================================================================

KOMETA_CONFIG=/config/config.yml
KOMETA_TIME=03:00
KOMETA_RUN=false
KOMETA_TEST=false
KOMETA_NO_MISSING=false

# ==============================================================================
# ICLOUDPD — iCloud Photos downloader
# ==============================================================================

ICLOUD_APPLE_ID=your@apple.com
ICLOUD_SYNC_INTERVAL=86400

# ==============================================================================
# DOZZLE — Docker log viewer
# Set a strong password. KEY is an optional HMAC secret for sessions.
# ==============================================================================

DOZZLE_USERNAME=admin
DOZZLE_PASSWORD=changeme
DOZZLE_KEY=changeme-random-secret

# ==============================================================================
# SPEEDTEST TRACKER — Internet speed monitoring
# APP_KEY: run `openssl rand -base64 32` to generate
# DB_CONNECTION: sqlite (default) or mysql/pgsql
# SPEEDTEST_SCHEDULE: cron expression (e.g. 0 * * * * = hourly)
# SPEEDTEST_SERVERS: comma-separated Ookla server IDs (empty = auto)
# SPEEDTEST_PRUNE_RESULTS_OLDER_THAN: days to keep results (0 = keep all)
# ==============================================================================

SPEEDTEST_APP_KEY=base64:changeme=
SPEEDTEST_DB_CONNECTION=sqlite
SPEEDTEST_SCHEDULE=0 * * * *
SPEEDTEST_SERVERS=
SPEEDTEST_PRUNE_RESULTS_OLDER_THAN=0

# ==============================================================================
# CHECKMATE — Uptime & status monitoring
# DB_CONNECTION_STRING: MongoDB URI (points to mongodb_checkmate container)
# REDIS_URL: Redis URI (points to redis_checkmate container)
# JWT_SECRET / TOKEN_TTL: auth config
# CLIENT_HOST / ORIGIN: set to your Checkmate web UI URL
# ==============================================================================

CHECKMATE_CLIENT_HOST=http://borg:3001
CHECKMATE_UPTIME_APP_API_BASE_URL=http://borg:52343/api/v1
CHECKMATE_UPTIME_APP_CLIENT_HOST=http://borg:3001
CHECKMATE_DB_CONNECTION_STRING=mongodb://mongodb_checkmate:27017/checkmate
CHECKMATE_JWT_SECRET=changeme-long-random-secret
CHECKMATE_TOKEN_TTL=3600000
CHECKMATE_ORIGIN=http://borg:3001
CHECKMATE_REDIS_URL=redis://redis_checkmate:6379
