# Paperless-ngx Configuration

# Database connection (must match postgres/.env)
PAPERLESS_DBHOST=paperless-postgres
PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=paperless
PAPERLESS_DBPASS=changeme_secure_password_here

# Redis connection
PAPERLESS_REDIS=redis://paperless-redis:6379

# Secret key (generate with: openssl rand -base64 32)
PAPERLESS_SECRET_KEY=changeme_generate_random_key_here

# Application URL
PAPERLESS_URL=http://borg:8000

# Timezone
PAPERLESS_TIME_ZONE=America/New_York

# OCR settings
PAPERLESS_OCR_LANGUAGE=eng

# Tika and Gotenberg integration
PAPERLESS_TIKA_ENABLED=1
PAPERLESS_TIKA_GOTENBERG_ENDPOINT=http://paperless-gotenberg:3000
PAPERLESS_TIKA_ENDPOINT=http://paperless-tika:9998

# Admin user (optional - for initial setup)
# PAPERLESS_ADMIN_USER=admin
# PAPERLESS_ADMIN_PASSWORD=changeme
# PAPERLESS_ADMIN_MAIL=admin@example.com
